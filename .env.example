# Environment variables for CCTV Centralization Platform

# Database settings
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cctv_db  # Use localhost for local dev, 'postgres' for Docker

# Backend settings
BACKEND_BACKEND_PORT=8000

# Frontend settings
FRONTEND_VITE_BACKEND_URL=http://localhost:8000

# Streaming settings
STREAMING_GO2RTC_HTTP_ADDRESS=:1984
STREAMING_GO2RTC_HOST=go2rtc                    # Docker internal hostname
STREAMING_GO2RTC_PUBLIC_URL=http://localhost:1984  # Browser-accessible URL
# Internal backend→go2rtc API URL (overrides host+port construction)
# Local dev (uvicorn on host):  http://localhost:1984
# Docker Compose full stack:    http://go2rtc:1984
STREAMING_GO2RTC_API_URL=http://localhost:1984

# Security settings
SECURITY_JWT_SECRET_KEY=your_jwt_secret_key
SECURITY_JWT_ALGORITHM=HS256
SECURITY_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60